# This is the top-most EditorConfig file
root = true

[*]
# Use UTF-8 encoding for all files
charset = utf-8
# Use Unix-style line endings (standard for Git/GitHub)
end_of_line = lf
# Insert a new line at the end of every file (best practice)
insert_final_newline = true
# Trim any accidental whitespace at the end of lines
trim_trailing_whitespace = true
# Set indentation to 2 spaces (standard for JS/Firebase)
indent_style = space
indent_size = 2

[*.md]
# Markdown files often need trailing whitespace for line breaks
trim_trailing_whitespace = false
